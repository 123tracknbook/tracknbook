{
  "expo": {
    "newArchEnabled": true,
    "name": "TracknBook",
    "slug": "tracknbook",
    "owner": "tracknbook",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/c994c889-170f-4fe5-a60b-b4b3e4f6b18d.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/iphone-splash-screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#0a1f2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "splash": {
        "image": "./assets/images/iphone-splash-screen.png",
        "resizeMode": "cover",
        "backgroundColor": "#0a1f2e",
        "tabletImage": "./assets/images/ipad-splash-screen.png"
      },
      "supportsTablet": true,
      "associatedDomains": [
        "webcredentials:tracknbook.app"
      ],
      "entitlements": {
        "com.apple.developer.associated-domains": [
          "webcredentials:tracknbook.app"
        ]
      },
      "bundleIdentifier": "com.tracknbook.app",
      "buildNumber": "1.0.7",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSExceptionDomains": {
            "tracknbook.app": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSExceptionRequiresForwardSecrecy": false,
              "NSExceptionMinimumTLSVersion": "TLSv1.0"
            },
            "www.tracknbook.app": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSExceptionRequiresForwardSecrecy": false,
              "NSExceptionMinimumTLSVersion": "TLSv1.0"
            }
          }
        },
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSLocationWhenInUseUsageDescription": "TracknBook uses your location to show nearby services and job sites.",
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
        "NSPhotoLibraryUsageDescription": "TracknBook accesses your photo library so team members can attach existing photos to jobs, such as before-and-after work photos, site issues, or completed work."
      }
    },
    "android": {
      "splash": {
        "image": "./assets/images/iphone-splash-screen.png",
        "resizeMode": "cover",
        "backgroundColor": "#0a1f2e"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/c994c889-170f-4fe5-a60b-b4b3e4f6b18d.png",
        "backgroundColor": "#000000"
      },
      "package": "com.tracknbook.app",
      "versionCode": 4,
      "permissions": [
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "FOREGROUND_SERVICE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "com.google.android.gms.permission.AD_ID",
        "READ_MEDIA_IMAGES"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/images/c994c889-170f-4fe5-a60b-b4b3e4f6b18d.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "react-native-edge-to-edge",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/c994c889-170f-4fe5-a60b-b4b3e4f6b18d.png",
          "color": "#000000",
          "sounds": [],
          "requestPermissionsOnLaunch": true
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "TracknBook uses your camera so team members can take photos for jobs, such as before-and-after work photos, site issues, or completed work, and attach them to the job record.",
          "photosPermission": "TracknBook accesses your photo library so team members can attach existing photos to jobs, such as before-and-after work photos, site issues, or completed work.",
          "microphonePermission": "TracknBook uses the microphone when capturing video so audio can be recorded alongside job footage."
        }
      ],
      "expo-tracking-transparency",
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "tracknbook",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "66b1f7d9-c56e-4b54-bd69-1aca90734eae"
      },
      "backendUrl": "https://x22c75gpnejzjbk2e7cztbaussb8z4ac.app.specular.dev",
      "nativelyProjectId": "d3434265-39a4-4a14-a988-80fa1687686a"
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/66b1f7d9-c56e-4b54-bd69-1aca90734eae"
    }
  }
}