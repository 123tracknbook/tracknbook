{
  "cli": {
    "version": ">= 3.13.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "resourceClass": "medium",
        "image": "latest"
      },
      "android": {
        "resourceClass": "medium",
        "image": "latest"
      }
    },
    "preview": {
      "channel": "preview",
      "env": { "NODE_ENV": "production", "EAS_BUILD": "true" },
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "medium",
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "medium",
        "image": "latest"
      }
    },
    "production": {
      "channel": "production",
      "env": { "NODE_ENV": "production", "EAS_BUILD": "true" },
      "ios": {
        "simulator": false,
        "resourceClass": "medium",
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "medium",
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "Luke_mendes@hotmail.co.uk",
        "ascAppId": "6760485930",
        "appleTeamId": "357U5YDBWK"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}